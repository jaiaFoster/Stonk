import robin_stocks.robinhood as r
import config

def get_positions():
try:
r.login(
username=config.ROBINHOOD_USERNAME,
password=config.ROBINHOOD_PASSWORD,
store_session=False,   # Don’t persist on server
by_sms=True            # MFA via SMS — change to by_email=True if needed
)

